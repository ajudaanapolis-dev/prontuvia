NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgresql://pep_runtime:pep_runtime_change_me@localhost:5432/pep
MIGRATION_DATABASE_URL=postgresql://pep_owner:pep_owner_change_me@localhost:5432/pep
WEB_ORIGIN=http://localhost:5173
COOKIE_SECRET=replace-with-at-least-32-random-characters
SESSION_PEPPER=replace-with-an-independent-32-char-secret
SESSION_TTL_HOURS=12
BOOTSTRAP_TENANT_NAME=Clínica Demonstração
BOOTSTRAP_ADMIN_NAME=Administrador Local
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=change-this-before-running-bootstrap
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=pep_local
MINIO_SECRET_KEY=replace-this-local-secret
MINIO_BUCKET=pep-documents
REDIS_URL=redis://localhost:6379

# CID-11 oficial (cadastro gratuito em https://icd.who.int/icdapi)
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=
WHO_ICD_RELEASE=2026-01
WHO_ICD_LANGUAGE=pt

# Cobrança SaaS: permanece manual até as credenciais Sandbox serem configuradas.
BILLING_PROVIDER=manual
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# WhatsApp Cloud API (Meta). Sem credenciais, mensagens permanecem em sandbox.
WHATSAPP_PROVIDER=sandbox
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-webhook-token
WHATSAPP_APP_SECRET=
WHATSAPP_CONFIRMATION_TEMPLATE=prontuvia_confirmacao_consulta
WHATSAPP_REMINDER_TEMPLATE=prontuvia_lembrete_consulta
WHATSAPP_ACCESS_CODE_TEMPLATE=prontuvia_codigo_acesso
NOTIFICATION_WORKER_INTERVAL_SECONDS=60

# Fundação clínica FHIR — Medplum self-hosted
MEDPLUM_VERSION=latest
MEDPLUM_BASE_URL=http://localhost:8103/
MEDPLUM_DATABASE_PASSWORD=medplum_local_change_me
MEDPLUM_REDIS_PASSWORD=medplum_local_change_me
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# Aplicativo clínico reutilizado do Medplum Provider
MEDPLUM_REGISTER_ENABLED=true

# NFSe. Sandbox autoriza apenas documentos fictícios locais.
NFSE_PROVIDER=sandbox
NFSE_API_TOKEN=

# Conciliação: OFX funciona localmente; Open Finance exige contrato.
BANK_RECONCILIATION_PROVIDER=ofx

# IA: disabled cria tarefas de revisão; local/openai exigem worker/credencial.
AI_PROVIDER=disabled
AI_API_KEY=
